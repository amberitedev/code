# Environment Variables
# Copy to .env.local and customize

# Modrinth API (uncomment to override defaults)
# Staging used automatically in dev, production in prod
# VITE_MODRINTH_API_URL=https://staging-api.modrinth.com/v2/
# VITE_MODRINTH_API_URL_V3=https://staging-api.modrinth.com/v3/

# Amberite Backend
VITE_AMBERITE_API_URL=http://localhost:3000/

# Supabase (optional)
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
