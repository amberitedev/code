{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "bash": {
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git fetch": "allow",
      "git fetch *": "allow",
      "git add .": "ask",
      "git add *": "ask",
      "git commit *": "ask",
      "git push *": "ask",
      "git pull *": "ask",
      "git reset *": "ask",
      "git merge *": "ask",
      "git branch *": "ask",
      "git rebase *": "ask",
      "git stash *": "ask",
      "git checkout *": "ask",
      "rm *": "ask",
      "del *": "ask",
      "rmdir *": "ask",
      "Remove-Item *": "ask"
    },
    "edit": "allow",
    "read": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "skill": "allow",
    "external_directory": {
        "*": "allow"
    }
  },
  "command": {}
}